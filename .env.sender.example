# NWC connection string for the SENDER wallet (pays invoices during e2e tests)
# This is separate from facilitator/.env which has NWC_URL (the receiver)
# Get this from a different NWC-compatible wallet (Alby, Mutiny, etc.)
SENDER_NWC_URL=nostr+walletconnect://

# Optional: override server URLs (defaults shown)
# FACILITATOR_URL=http://localhost:3000
# APP_URL=http://localhost:4000
