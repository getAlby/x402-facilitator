# NWC connection string for the SENDER wallet (pays invoices during e2e tests)
# Must be a different wallet from DEMO_NWC_SECRET (the receiver)
# Get this from any NWC-compatible wallet (Alby, Mutiny, etc.)
# Full format: nostr+walletconnect://<pubkey>?relay=wss://<relay-host>/v1&secret=<secret>
SENDER_NWC_SECRET=nostr+walletconnect://<pubkey>?relay=wss://relay.getalby.com/v1&secret=<secret>

# Optional: override server URLs for e2e tests (defaults shown)
# FACILITATOR_URL=http://localhost:3000
# APP_URL=http://localhost:3000/demo
