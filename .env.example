# Required: Redis connection URL
REDIS_URL=redis://localhost:6379

# Optional: HTTP port (default: 3000)
PORT=3000

# Optional: public base URL used in /.well-known/x402 (default: http://localhost:$PORT)
BASE_URL=https://your-domain.com

# NWC connection string for the merchant/receiver wallet
# Enables the /demo/quote endpoint and the /register flow
DEMO_NWC_SECRET=nostr+walletconnect://<pubkey>?relay=<relay>&secret=<secret>

# NWC connection string for the SENDER wallet (used in e2e tests to pay invoices)
# Must be a different wallet from DEMO_NWC_SECRET
SENDER_NWC_SECRET=nostr+walletconnect://<pubkey>?relay=<relay>&secret=<secret>

# Optional: override server URLs for e2e tests (defaults shown)
# FACILITATOR_URL=http://localhost:3000
# APP_URL=http://localhost:3000/demo
